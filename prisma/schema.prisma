// Data model for the online portfolio (a Seesaw-like class journal).
// SQLite has no native enums, so "type"/"status"/"role" fields are plain
// strings with their allowed values documented in comments next to them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A teacher owns one or more classes and moderates the journal.
model Teacher {
  id           String    @id @default(cuid())
  name         String // the teacher's full name (e.g. "Sam Pearson")
  title        String? // Mr / Miss / Mrs / Ms / Mx, or "" for "prefer not to say"
  displayStyle String    @default("formal") // "formal" (title + surname) | "first"
  displayName  String? // computed greeting name, e.g. "Mr Pearson" or "Sam" — never derive the greeting from `name`
  email        String    @unique
  passwordHash String
  schoolName   String? // captured at signup (Storyjar onboarding); free text
  country      String? // England / Scotland / Wales / NI / Elsewhere
  role         String    @default("TEACHER") // ADMIN | TEACHER | TA — position within the school
  status       String    @default("ACTIVE") // ACTIVE | INVITED (invited staff haven't set a password yet)
  school       School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  schoolId     String?
  createdAt    DateTime  @default(now())
  classes      Class[]
  sessions     Session[]
  templates    ActivityTemplate[]
  folders      Folder[]
  drafts       Draft[] // in-progress template drafts (cross-device autosave)
  // An individually-subscribing teacher's own subscription (null when the
  // teacher is covered by a school plan instead — see Subscription).
  subscription Subscription?
}

// A school groups staff (teachers/TAs/admins) under one roof. Admins manage
// staff, class assignment and billing — but never see children's work unless
// they teach the class (that stays scoped to each teacher's own classes).
model School {
  id           String        @id @default(cuid())
  name         String
  seatLimit    Int           @default(10) // paid seats on the school plan
  createdAt    DateTime      @default(now())
  staff        Teacher[]
  // The school's billing subscription (school plan). Null until one is created;
  // the plan label shown in the admin console is derived from this, not stored.
  subscription Subscription?
}

// A billing subscription that governs WRITE access for an account. An account is
// either one teacher (kind = INDIVIDUAL) or a whole school (kind = SCHOOL).
//
// Safeguarding notes:
//  - We store only Stripe identifiers here — never card/PAN data (rule 12).
//  - No child data ever lives on this record (hard constraint): a customer is
//    only ever a teacher's name/email or a school name, held in Stripe.
//  - `status` is the enforcement point read by requireWritableAccount(); FROZEN
//    means read-only. `frozenAt` starts the 12-month deletion clock in
//    RETENTION.md. Subscription rows are billing records (6-year retention).
model Subscription {
  id                   String    @id @default(cuid())
  kind                 String // INDIVIDUAL | SCHOOL
  status               String    @default("TRIAL") // TRIAL | ACTIVE | PAST_DUE | FROZEN
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  trialEndsAt          DateTime // 42-day "free half term" from signup; tracked locally, not via Stripe trials
  frozenAt             DateTime? // when the account went read-only (starts the 12-month clock)
  seatLimit            Int? // school plan: paid seat count (Stripe quantity); mirrors School.seatLimit
  currentPeriodEnd     DateTime? // end of the current paid period, synced from Stripe
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Exactly one of these is set (INDIVIDUAL → teacher, SCHOOL → school).
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String?  @unique
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId  String?  @unique
}

// Processed Stripe webhook event ids, so at-least-once redelivery is handled
// exactly once (idempotency). No personal data — just the event id and type.
model BillingEvent {
  id         String   @id // the Stripe event id (evt_...)
  type       String
  receivedAt DateTime @default(now())
}

// A teacher-defined folder for organising activity templates in the library.
model Folder {
  id        String             @id @default(cuid())
  name      String
  color     String             @default("#C9C2B0") // the sidebar dot colour
  teacher   Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  createdAt DateTime           @default(now())
  templates ActivityTemplate[]
}

// A class groups students together and has a short code students use to log in.
model Class {
  id           String        @id @default(cuid())
  name         String
  yearGroup    String? // e.g. "Year 2" — captured at signup
  classCode    String        @unique // e.g. "SUN123" — students type this to sign in
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId    String
  createdAt    DateTime      @default(now())
  students     Student[]
  journalItems JournalItem[]
  assignments  Assignment[]
  drafts       Draft[]
}

// A student has no password — they pick their name from the class after
// entering the class code (mirrors how Seesaw handles young children).
model Student {
  id           String        @id @default(cuid())
  name         String
  avatarColor  String        @default("#4f46e5") // colour of their avatar bubble
  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId      String
  createdAt    DateTime      @default(now())
  journalItems JournalItem[]
  sessions     Session[]
  assignments  AssignmentStudent[]
  parents      Parent[]      @relation("ParentChildren")
  drafts       Draft[] // in-progress activity-response drafts (cross-device autosave)
}

// A parent/carer with a read-only family view of their own child(ren)'s jar.
// They sign in with a teacher-issued family code or an emailed magic link — no
// password — and can only ever see approved moments for their linked children.
model Parent {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  familyCode  String       @unique // the code printed on the school's letter
  createdAt   DateTime     @default(now())
  children    Student[]    @relation("ParentChildren")
  sessions    Session[]
  magicTokens MagicToken[]
}

// A single-use, expiring token behind a parent "magic link" email.
model MagicToken {
  id        String    @id @default(cuid())
  token     String    @unique
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// A single piece of work in a student's journal.
model JournalItem {
  id          String    @id @default(cuid())
  type        String // PHOTO | TEXT | DRAWING
  caption     String? // optional short caption / the child's words
  textContent String? // body text for TEXT items
  mediaPath   String? // relative path under /public/uploads for PHOTO / DRAWING items (single / cover image)
  mediaPathsJson String? // JSON array of paths for multi-page drawings; when set it supersedes mediaPath
  quizAnswersJson String? // JSON QuizAnswer[] — the child's multiple-choice selections (PENDING child content)
  quizScore   Int? // server-computed number of correct answers at submit time (null = not a quiz response)
  quizTotal   Int? // number of questions in the assignment snapshot at submit time
  status      String    @default("PENDING") // PENDING | APPROVED | RETURNED
  authorRole  String // STUDENT | TEACHER — who created the item
  teacherNote String? // feedback the teacher leaves when returning work
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  skills      Skill[]   @relation("JournalItemSkills")
  createdAt   DateTime  @default(now())
  approvedAt  DateTime?
  // When set, this item is a response to an assignment (a run of a template).
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  assignmentId String?
}

// A reusable, class-agnostic activity a teacher can run again and again. The
// unit of organisation in the activity library. (Formerly `Activity`.)
model ActivityTemplate {
  id                String       @id @default(cuid())
  title             String
  instructions      String? // what to do; may be read aloud to the child
  templatePathsJson String? // JSON array of background image paths (canvas / PDF pages)
  quizJson          String? // JSON QuizPayload — floating multiple-choice questions; option imagePaths are /uploads paths
  tagsJson          String? // JSON array of teacher-defined tag names (e.g. ["Maths"])
  archived          Boolean      @default(false) // hidden from the grid; runs are kept
  teacher           Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId         String
  folder            Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folderId          String?
  createdAt         DateTime     @default(now())
  assignments       Assignment[]
}

// One run of a template against a class (whole class or chosen children).
// Title / instructions / template pages are snapshotted here at assign time so
// later edits to the template never change what a live run shows.
model Assignment {
  id                   String              @id @default(cuid())
  template             ActivityTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId           String
  class                Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId              String
  wholeClass           Boolean             @default(true)
  status               String              @default("LIVE") // LIVE | CLOSED
  title                String // snapshot at assign time
  instructions         String? // snapshot at assign time
  templateSnapshotJson String? // frozen template pages at assign time
  quizSnapshotJson     String? // frozen quiz definition at assign time (mirrors templateSnapshotJson)
  dueDate              DateTime? // optional: when the run is expected done; null = no due date (open/historical)
  createdAt            DateTime            @default(now())
  students             AssignmentStudent[] // set only when wholeClass = false
  responses            JournalItem[]
  drafts               Draft[]
}

// An in-progress, unsubmitted draft synced to the account for cross-device
// resume (local-first autosave, Stage 2). Exactly one owner is set: a teacher
// (a new-template draft) OR a student (an activity-response draft). Composite
// pages are stored as MEDIA FILES (like real pages) and only their /uploads
// paths live in pagesJson — never multi-MB data URLs in a column.
//
// SAFEGUARDING: a child's draft is their private unfinished work. It is owner-
// scoped, never visible to parents/other children/other tenants, and never to a
// teacher (a teacher only sees the work once it's submitted as a JournalItem).
// Deletion is real (rows + media files), on submit/publish, on 30-day lazy
// expiry, and on owner cascade. See RETENTION.md.
model Draft {
  id         String   @id @default(cuid())
  surface    String // TEMPLATE_NEW | ACTIVITY_RESPONSE
  contextKey String // "tmpl-new" for a teacher, or the assignmentId for a response
  ownerKey   String // "t:<teacherId>" or "s:<studentId>" — the non-null uniqueness discriminator (nullable FKs alone can't dedupe in SQLite, where NULLs are distinct)
  pagesJson  String? // JSON array of /uploads paths (composite pages saved as media)
  fieldsJson String? // JSON of the wrapper's fields (title/instructions/tags OR caption)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime // now + retention; lazily purged (no cron)

  // Owner + context so cascade deletion and scoping are trivial. All Cascade so
  // a draft dies with its owner (teacher/student/class/assignment).
  teacher      Teacher?    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId    String?
  student      Student?    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String?
  class        Class?      @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId      String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String?

  // One draft per (owner, context).
  @@unique([surface, contextKey, ownerKey])
  @@index([expiresAt])
}

// A chosen child on a "pick children" run. (Formerly `ActivityAssignment`.)
model AssignmentStudent {
  id           String     @id @default(cuid())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  createdAt    DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

// A skill / standard an item can be tagged against, so the journal doubles
// as assessment evidence. Shared across the whole app.
model Skill {
  id    String        @id @default(cuid())
  name  String        @unique
  items JournalItem[] @relation("JournalItemSkills")
}

// A login session. Points at a teacher, a student, or a parent.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  role      String // TEACHER | STUDENT | PARENT
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String?
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// An append-only record of safeguarding-relevant actions (approvals, returns,
// deletions, staff/role changes) for accountability — SAFEGUARDING.md rule 16.
// Kept deliberately lightweight: actor, action, subject, time and a short note.
model AuditLog {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  schoolId    String? // for school-scoped viewing (from the actor's school)
  actorType   String // TEACHER | ADMIN | SYSTEM
  actorId     String?
  actorName   String?
  action      String // e.g. MOMENT_APPROVED | MOMENT_RETURNED | STAFF_ROLE_CHANGED
  subjectType String? // e.g. JOURNAL_ITEM | STUDENT | TEACHER | CLASS
  subjectId   String?
  detail      String? // short human-readable summary

  @@index([schoolId, at])
}
