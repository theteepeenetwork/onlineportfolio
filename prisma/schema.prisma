// Data model for the online portfolio (a Seesaw-like class journal).
// SQLite has no native enums, so "type"/"status"/"role" fields are plain
// strings with their allowed values documented in comments next to them.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A teacher owns one or more classes and moderates the journal.
model Teacher {
  id           String    @id @default(cuid())
  name         String // the teacher's full name (e.g. "Sam Pearson")
  title        String? // Mr / Miss / Mrs / Ms / Mx, or "" for "prefer not to say"
  displayStyle String    @default("formal") // "formal" (title + surname) | "first"
  displayName  String? // computed greeting name, e.g. "Mr Pearson" or "Sam" — never derive the greeting from `name`
  email        String    @unique
  passwordHash String
  schoolName   String? // captured at signup (Storyjar onboarding); free text
  country      String? // England / Scotland / Wales / NI / Elsewhere
  role         String    @default("TEACHER") // ADMIN | TEACHER | TA — position within the school
  status       String    @default("ACTIVE") // ACTIVE | INVITED (invited staff haven't set a password yet)
  school       School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  schoolId     String?
  createdAt    DateTime  @default(now())
  classes      Class[]
  sessions     Session[]
  templates    ActivityTemplate[]
  folders      Folder[]
}

// A school groups staff (teachers/TAs/admins) under one roof. Admins manage
// staff, class assignment and billing — but never see children's work unless
// they teach the class (that stays scoped to each teacher's own classes).
model School {
  id        String    @id @default(cuid())
  name      String
  plan      String    @default("Annual plan") // billing plan label
  seatLimit Int       @default(10)
  createdAt DateTime  @default(now())
  staff     Teacher[]
}

// A teacher-defined folder for organising activity templates in the library.
model Folder {
  id        String             @id @default(cuid())
  name      String
  color     String             @default("#C9C2B0") // the sidebar dot colour
  teacher   Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  createdAt DateTime           @default(now())
  templates ActivityTemplate[]
}

// A class groups students together and has a short code students use to log in.
model Class {
  id           String        @id @default(cuid())
  name         String
  yearGroup    String? // e.g. "Year 2" — captured at signup
  classCode    String        @unique // e.g. "SUN123" — students type this to sign in
  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId    String
  createdAt    DateTime      @default(now())
  students     Student[]
  journalItems JournalItem[]
  assignments  Assignment[]
}

// A student has no password — they pick their name from the class after
// entering the class code (mirrors how Seesaw handles young children).
model Student {
  id           String        @id @default(cuid())
  name         String
  avatarColor  String        @default("#4f46e5") // colour of their avatar bubble
  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId      String
  createdAt    DateTime      @default(now())
  journalItems JournalItem[]
  sessions     Session[]
  assignments  AssignmentStudent[]
  parents      Parent[]      @relation("ParentChildren")
}

// A parent/carer with a read-only family view of their own child(ren)'s jar.
// They sign in with a teacher-issued family code or an emailed magic link — no
// password — and can only ever see approved moments for their linked children.
model Parent {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  familyCode  String       @unique // the code printed on the school's letter
  createdAt   DateTime     @default(now())
  children    Student[]    @relation("ParentChildren")
  sessions    Session[]
  magicTokens MagicToken[]
}

// A single-use, expiring token behind a parent "magic link" email.
model MagicToken {
  id        String    @id @default(cuid())
  token     String    @unique
  parent    Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// A single piece of work in a student's journal.
model JournalItem {
  id          String    @id @default(cuid())
  type        String // PHOTO | TEXT | DRAWING
  caption     String? // optional short caption / the child's words
  textContent String? // body text for TEXT items
  mediaPath   String? // relative path under /public/uploads for PHOTO / DRAWING items (single / cover image)
  mediaPathsJson String? // JSON array of paths for multi-page drawings; when set it supersedes mediaPath
  status      String    @default("PENDING") // PENDING | APPROVED | RETURNED
  authorRole  String // STUDENT | TEACHER — who created the item
  teacherNote String? // feedback the teacher leaves when returning work
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  skills      Skill[]   @relation("JournalItemSkills")
  createdAt   DateTime  @default(now())
  approvedAt  DateTime?
  // When set, this item is a response to an assignment (a run of a template).
  assignment   Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  assignmentId String?
}

// A reusable, class-agnostic activity a teacher can run again and again. The
// unit of organisation in the activity library. (Formerly `Activity`.)
model ActivityTemplate {
  id                String       @id @default(cuid())
  title             String
  instructions      String? // what to do; may be read aloud to the child
  templatePathsJson String? // JSON array of background image paths (canvas / PDF pages)
  tagsJson          String? // JSON array of teacher-defined tag names (e.g. ["Maths"])
  archived          Boolean      @default(false) // hidden from the grid; runs are kept
  teacher           Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId         String
  folder            Folder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  folderId          String?
  createdAt         DateTime     @default(now())
  assignments       Assignment[]
}

// One run of a template against a class (whole class or chosen children).
// Title / instructions / template pages are snapshotted here at assign time so
// later edits to the template never change what a live run shows.
model Assignment {
  id                   String              @id @default(cuid())
  template             ActivityTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId           String
  class                Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId              String
  wholeClass           Boolean             @default(true)
  status               String              @default("LIVE") // LIVE | CLOSED
  title                String // snapshot at assign time
  instructions         String? // snapshot at assign time
  templateSnapshotJson String? // frozen template pages at assign time
  dueDate              DateTime? // optional: when the run is expected done; null = no due date (open/historical)
  createdAt            DateTime            @default(now())
  students             AssignmentStudent[] // set only when wholeClass = false
  responses            JournalItem[]
}

// A chosen child on a "pick children" run. (Formerly `ActivityAssignment`.)
model AssignmentStudent {
  id           String     @id @default(cuid())
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  createdAt    DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

// A skill / standard an item can be tagged against, so the journal doubles
// as assessment evidence. Shared across the whole app.
model Skill {
  id    String        @id @default(cuid())
  name  String        @unique
  items JournalItem[] @relation("JournalItemSkills")
}

// A login session. Points at a teacher, a student, or a parent.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  role      String // TEACHER | STUDENT | PARENT
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String?
  parent    Parent?  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  parentId  String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// An append-only record of safeguarding-relevant actions (approvals, returns,
// deletions, staff/role changes) for accountability — SAFEGUARDING.md rule 16.
// Kept deliberately lightweight: actor, action, subject, time and a short note.
model AuditLog {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  schoolId    String? // for school-scoped viewing (from the actor's school)
  actorType   String // TEACHER | ADMIN | SYSTEM
  actorId     String?
  actorName   String?
  action      String // e.g. MOMENT_APPROVED | MOMENT_RETURNED | STAFF_ROLE_CHANGED
  subjectType String? // e.g. JOURNAL_ITEM | STUDENT | TEACHER | CLASS
  subjectId   String?
  detail      String? // short human-readable summary

  @@index([schoolId, at])
}
