{
  "name": "onlineportfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "setup": "prisma db push && tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:test": "FORCE_SEED=1 tsx prisma/seed-test.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",

    "test:e2e": "playwright test",
    "test:security": "node scripts/audit-static.mjs && node scripts/check-r2-tripwire.mjs && npm run audit:prod && playwright test -c playwright.battery.config.ts --project=security",
    "test:security:findings": "playwright test -c playwright.battery.config.ts --project=security-findings",
    "test:a11y": "playwright test -c playwright.battery.config.ts --project=a11y",
    "test:ux": "playwright test -c playwright.battery.config.ts --project=ux",
    "test:perf": "lhci autorun || true",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:errors": "node scripts/error-string-audit.mjs",
    "test:battery": "npm run test:security && npm run test:a11y && npm run test:ux && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "next": "16.2.10",
    "pdfjs-dist": "^6.1.200",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tsx": "^4.23.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "engines": {
    "node": "22.x"
  }
}
