# Storyjar environment — copy to `.env` and fill in. NEVER commit real values.
# Secrets come from the environment only (SAFEGUARDING.md rule 12).

# --- Core ---
# SQLite in dev; a UK/EU-hosted database in production (SAFEGUARDING rule 10).
DATABASE_URL="file:./dev.db"

# Where uploaded children's media is stored (private dir, served via /uploads).
# MEDIA_DIR="/data/media"

# Absolute base URL of the app, used to build Stripe return links. Optional in
# dev (derived from the request host); set it in production.
# APP_URL="https://storyjar.co.uk"

# --- Billing (Stripe) ---
# Stripe processes ADULT billing data only (teacher name/email or school name).
# No child data is ever sent to Stripe. See README "Billing" for setup.
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs created in Stripe (test/live). GBP, VAT-inclusive. See the README for
# the Stripe CLI commands that create these.
STRIPE_PRICE_INDIVIDUAL_MONTHLY="price_..."   # £3.99 / month
STRIPE_PRICE_INDIVIDUAL_ANNUAL="price_..."    # £40 / year
STRIPE_PRICE_SCHOOL_SEAT_ANNUAL="price_..."   # £40 / seat / year (quantity = seats)

# Apple Pay domain-association file contents, from the Stripe dashboard
# (Payment methods → Apple Pay → your domain). Served at
# /.well-known/apple-developer-merchantid-domain-association. Not secret.
STRIPE_APPLE_PAY_DOMAIN_ASSOCIATION=""
